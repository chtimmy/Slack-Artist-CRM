# Artist CRM — environment template.
# Copy this file to server/.env and fill in real values. Never commit server/.env.

# --- Claude (Anthropic) -----------------------------------------------------
# API key used for intent classification (Haiku) and artist/marketing summaries (Sonnet).
ANTHROPIC_API_KEY=

# --- Google OAuth (Sheets + Drive) ------------------------------------------
# OAuth client ID from the Google Cloud project (Desktop app credential).
GOOGLE_CLIENT_ID=
# OAuth client secret matching the client ID above.
GOOGLE_CLIENT_SECRET=

# --- Slack ------------------------------------------------------------------
# Bot User OAuth token (starts with xoxb-) — the bot's identity in the workspace.
SLACK_BOT_TOKEN=
# App-level token (starts with xapp-) — required for Socket Mode (no public webhook).
SLACK_APP_TOKEN=
# Comma-separated Slack user IDs allowed to talk to the bot, or * to allow anyone
# in the workspace (fail-closed: empty means the bot responds to no one).
SLACK_AUTHORIZED_USER_IDS=
# Comma-separated Slack user IDs always granted the admin role (RBAC bootstrap / recovery).
SLACK_ADMIN_USER_IDS=
# Optional startup guard: the expected Slack workspace/team ID; the bot refuses to
# run against a different workspace. Strongly recommended when SLACK_AUTHORIZED_USER_IDS=*.
SLACK_WORKSPACE_ID=

# --- Artist CRM sheet + Drive folders ---------------------------------------
# URL of the CRM Google Sheet. Auto-populated by `python3 tools/artist_crm.py --provision`.
ARTIST_CRM_SHEET_URL=
# Optional: comma-separated emails to share the raw sheet with (direct read/audit access).
# Leave blank if the team only uses the bot.
ARTIST_CRM_TEAM_EMAILS=
# Optional: a specific Drive folder ID to upload artist files into. Leave blank to use
# the auto-managed "Artist Assets" folder (see ARTIST_CRM_ASSETS_FOLDER_ID).
ARTIST_CRM_DRIVE_FOLDER_ID=
# The "Artist Assets" folder ID (inside "Artist Repository") that holds per-artist asset
# subfolders. Auto-populated on first file upload — leave blank initially.
ARTIST_CRM_ASSETS_FOLDER_ID=
